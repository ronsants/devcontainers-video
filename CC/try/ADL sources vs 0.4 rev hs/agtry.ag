DATA Architecture  | Arch cs:Contexts
DATA Context       | Ctx nm:String on:{[String]} isa:{Inheritance Concept} world:{[Classification Context]} dc:Patterns ms:Signatures cs:ConceptDefs
DATA Pattern       | Pat nm:String rules:Rules gen:Gens pms:Signatures cs:ConceptDefs
DATA Rule          | Ru c:Char antc:Expression rulePos:{FilePos} cons:Expression expl:String sgn:{(Concept,Concept)} nr:Int
                   | Gc gluePos:{FilePos} m:Morphism expr:Expression sgn:{(Concept,Concept)} nr:Int
DATA Expression    | Tm m:Morphism compl:Bool
                   | Tf f:Morphism compl:Bool
                   | Tc c:Expression compl:Bool
                   | F ts:Expressions
                   | Fu fs:Expressions
                   | Fi fs:Expressions
DATA Signature     | Sgn nm:String a:Concept b:Concept props:{[Prop]} prL:String prM:String prR:String content:{[Link]} morPos:{FilePos}
                   | Idn c:Concept morPos:FilePos
DATA Morphism      | Mph nm:String pos:FilePos atts:{[Concept]} sgn:{(Concept,Concept)} m:Signature
                   | Id pos:FilePos atts:{[Concept]} c:Concept
DATA Prop          | Uni | Tot | Inj | Sur | Sym | Asy | Trn
DATA Gen           | G genus:Concept spec:Concept
DATA Concept       | C c:String gE:GenR os:{[String]}
DATA ConceptDef    | Cd pos:{FilePos} nm:String def:String ref:String
TYPE ConceptDefs   = [ConceptDef]
TYPE Contexts      = [Context]
TYPE Gens          = [Gen]
TYPE Rules         = [Rule]
TYPE Expressions   = [Expression]
TYPE Concepts      = [Concept]
TYPE Signatures    = [Signature]
TYPE Patterns      = [Pattern]
TYPE Links         = [Link]

imports
{
import UU_Scanner
import UU_Pretty
import Auxiliaries
import Classification
import Typology
import CC_aux
}

{

mkCtxAG :: [(Context,(Gens,Signatures))] -> String -> Classification (Context,(Gens,Signatures))
mkCtxAG ctxs ctxName
 = if null ctTrees
   then error ("!Error of type 0: unknown context "++ctxName
               ++".\ntesting: length ctxs="++show (length ctxs)
               ++if length ctxs>1
                 then ".\nPick one of "++chain ", " (map (name.fst) (tail ctxs))++" or "++(name.fst.head) ctxs
                 else if null ctxs then "No context available" else ".\nPick "++(name.fst.head) ctxs
              ) else
   let ecl = [head cl|cl<-eqClass (==) (map (name.fst) ctxs), length cl>1] in
   if null ecl then head ctTrees else
   error ("!Error of type 0: multiple contexts carrying the name "++commaAnd ecl++".")
   where
    ctTrees = [t|tree<-trees, t<-locatesF ((==ctxName).name.fst) tree]
-- multiple ctTrees may occur if contexts are used multiply in different ctTrees.
    trees = makeClassificationsF (name.fst) tuples++[Cl s []| s<-singles]
            where tuples = [ ((spc,(mG,mD)),(gen,(mG',mD')))
                           | (spc@(Ctx nm on isa world dc ms cs),(mG,mD))<-ctxs, o<-on
                           , (gen,(mG',mD'))<-ctxs,name gen==o]
                  singles= [ (spc,(mG,mD))
                           | (spc,(mG,mD))<-ctxs, not (name spc `elem` rd [name c|(s,g)<-tuples, (c,m)<-[s,g]])]
}

ATTR Contexts Context [ ctxs:{[(Context,(Gens,Signatures))]} | | over:{[(Context,(Gens,Signatures))]} ]
ATTR Context [ ctxTree:{Classification (Context,(Gens,Signatures))} | | ]
ATTR Architecture
     [ | | cs:{[Context]}]
SEM Architecture
  | Arch lhs.cs     = @cs.contexts
         cs.ctxs    = @cs.over
SEM Contexts 
  | Cons lhs.over   = @hd.over ++ @tl.over
         hd.ctxTree = mkCtxAG @lhs.ctxs (name @hd.context)
  | Nil  lhs.over   = []
SEM Context
  | Ctx loc.mD      = concat[mD| (ctx,(mG,mD)) <- preCl @lhs.ctxTree] -- all signatures in context
        loc.mGen    = (rd.concat) [mG| (ctx,(mG,mD)) <- preCl @lhs.ctxTree]
        loc.inh     = Isa [(g,s)|G g s<- @mGen] (concs @mD>-rd [c|G g s<- @mGen, c<-[g,s]])
        loc.genE    = cmp where cmp (Anything _) b = True
                                cmp a (Anything _) = False
                                cmp a b            = if a==b then True else genEq (typology @inh) a b
        loc.cD      = makeConceptSpace @dc.morphisms
        dc.mDef     = @mD
        dc.gE       = @genE
        ms.gE       = @genE
        lhs.over    = [( populate @cD (Ctx @nm @on @inh [] @dc.patterns @ms.signatures @cs.conDefs)
                       , (@dc.mGen, @ms.signatures ++ @dc.signatures))]
        lhs.context = populate @cD (Ctx @nm @on @inh [cl|Cl r cls<-[mapCl fst @lhs.ctxTree], cl<-cls]
                                        @dc.patterns @ms.signatures (sort' name (rd (@cs.conDefs ++ @dc.conDefs))))

ATTR Patterns Pattern Rule Rules Expression Expressions Morphism
     [ mDef:Signatures gE:GenR | | ]
ATTR Rule Rules Pattern Patterns [ | | mGen:Gens ]
SEM Patterns 
  | Cons lhs.mGen   = @hd.mGen ++ @tl.mGen
  | Nil  lhs.mGen   = []
SEM Pattern
  | Pat lhs.mGen    = clearG (@rules.mGen ++ @gen.list)
SEM Rules
  | Cons lhs.mGen   = @hd.mGen ++ @tl.mGen
  | Nil  lhs.mGen   = []
SEM Rule
  | Ru lhs.mGen     = []
  | Gc lhs.mGen     = clearG [g| (d,c) <- @expr.signs, m <- @m.mors, g<-[G d (source m), G c (target m)]]

SEM Rule
  | Ru loc.s        = irredT @lhs.gE [ (if a `@lhs.gE` a' then a' else a, if b `@lhs.gE` b' then b' else b)
                                     | (a,b)<- @cons.signs, (a',b')<- @antc.signs
                                     , (a `@lhs.gE` a' || a' `@lhs.gE` a) && (b `@lhs.gE` b' || b' `@lhs.gE` b)
                                     ]
       loc.is       = if null @antc.signs 
                      then if null @cons.signs
                           then []
                           else @cons.signs
                      else if null @cons.signs
                           then @antc.signs
                           else @s
       antc.isign   = if null @is then @antc.signs else @is
       cons.isign   = if null @is then @cons.signs else @is
       antc.pos     = @rulePos
       cons.pos     = @rulePos
  | Gc m.isign      = @ms
       expr.isign   = irredT @lhs.gE @expr.signs
       loc.ms       = irredT @lhs.gE
                       (if null @expr.signs
                        then [(source m,target m)| m <- @m.mors]
                        else [(source m,target m)| m <- @m.mors
                                                 , or[s `@lhs.gE` source m && t `@lhs.gE` target m
                                                     | (s,t) <- @expr.signs ]
                             ])
       loc.esign    = irredT @lhs.gE @expr.signs
       expr.pos     = @gluePos
       m.pos        = @gluePos
{
llub gE ss ss'
 = if null ss'
   then if null ss
        then []
        else ss
   else if null ss
        then ss'
        else rd [ (if a `gE` a' then a' else a, if b `gE` b' then b' else b)
                | (a,b)<-ss, (a',b')<-ss'
                , (a `gE` a' || a' `gE` a) && (b `gE` b' || b' `gE` b)
                ]
tlub gE cs [] = []
tlub gE [] cs = []
tlub gE as bs = (map (foldr1 lub) . eqClass order) [lub a b| a<-as, b<-bs, a `order` b]
                where lub (Anything _) b = b
                      lub a (Anything _) = a
                      lub a b = if a `gE` b then b else a
                      order (Anything _) b = True
                      order a (Anything _) = True
                      order a b = a `gE` b || b `gE` a
comp gE [] ts = []
comp gE ss [] = []
comp gE ss ts = [(f a a' b,f b' a' b)|(a,b)<-ss, (a',b')<-ts, a' `gE` b || b `gE` a']
                where f (Anything _) x y | x `gE` y = y
                                         | y `gE` x = x
                      f a _ _ = a
comps gE tss  = if null ss then [] else foldr1 (comp gE) ss
                where ss=[s|s<-tss, not (null s)]
distr (a,b) css ts = if and [length cs<=1|cs<-css]
                     then [specialize (x,y) t| (x,y,t)<-zip3 ([a]++cs) (cs++[b]) ts]
                     else error ("Fatal: ambiguities "++show css)
                     where cs  = [c|[c]<-css]
}
ATTR Expression [ | | expr:Expression ]
ATTR Expressions [ septets:{[(Concept, Expressions, [(Concept,Concept)], [Concept], [(Concept,Concept)], Expressions, Concept)]} | | signss:{[[(Concept,Concept)]]} ]
ATTR Expression Morphism [ | | signs:{[(Concept,Concept)]} ]
ATTR Expression Expressions Morphism [ pos:FilePos  | | ]
ATTR Expression Expressions Morphism [ isign:{[(Concept,Concept)]} | | ] -- in Expression only for Tm, Tf, Tc, Fi, Fu
SEM Expression
  | Tm lhs.signs    = @m.signs
       lhs.expr     = Tm @m.morphism @compl
  | Tf lhs.signs    = [ (b,a)| (a,b) <- @f.signs]
       f.isign      = [ (b,a)| (a,b) <- @lhs.isign]
       lhs.expr     = Tf @f.morphism @compl
  | Tc lhs.signs    = @c.signs
       lhs.expr     = Tc @c.expr @compl
  | F  lhs.signs    = @sgns
       loc.sgns     = comps @lhs.gE @ts.signss
       loc.trpls    = -- multiple elements in @lhs.isign will be signalled by the type checker, so that is not a fatal error.
                      [ (a,l,sl,tlub @lhs.gE (rd(map snd sl)) (rd(map fst sr)),sr,r,b)
                      | ((l,r),(sls,srs))<-zip (chop @ts.exprs) (chop @ts.signss) -- none of l, r, sls, srs are empty because of chop's property.
                      , (a,b) <- take 1 @lhs.isign
                      , sl <- [comps @lhs.gE sls]
                      , sr <- [comps @lhs.gE srs]
                      ]
       lhs.expr     = @dis
       loc.dis      = F (if length @ts.exprs==1 then @ts.exprs else 
                         distr (s,t) [cs|(a,l,sl,cs,sr,r,b)<- @trpls, a==s, b==t] @ts.exprs)
                      where (s,t)= if null @lhs.isign then error("Fatal: ("++show @lhs.pos++") cannot compute distribution with empty @lhs.isign and @ts.exprs="++show @ts.exprs++
                                             "\n@trpls:     "++chain "\n->          " [show a++"#"++show ls++"#"++show sl++"#"++show cs++"#"++show sr++"#"++show rs++"#"++show b|(a,ls,sl,cs,sr,rs,b)<- @trpls])
                                   else
                                   head @lhs.isign -- @lhs.isign has length 1, or else there is a type error.
       ts.septets   = @trpls
  | Fu lhs.signs    = @sgns
       loc.sgns     = if null @fs.signss then error("Fatal: empty @fs.signss in expression "++showHS (Fu @fs.exprs)) else
                      foldr1 (llub @lhs.gE) @fs.signss
       fs.septets   = []
       lhs.expr     = Fu @fs.exprs
  | Fi lhs.signs    = @sgns
       loc.sgns     = if null @fs.signss then error("Fatal: empty @fs.signss in expression "++showHS (Fi @fs.exprs)) else
                      foldr1 (llub @lhs.gE) @fs.signss
       fs.septets   = []
       lhs.expr     = Fi @fs.exprs
SEM Expressions
  | Cons lhs.signss = @hd.signs: @tl.signss
         hd.isign   = if null @lhs.septets then @lhs.isign else
                      --if null @hsgn then error ("Fatal: null @hsgn on "++show @lhs.pos++"\n@tl.exprs=="++show @tl.exprs++"\n@lhs.isign = "++show @lhs.isign++"\n@lhs.septets = \n"++chain "\n" ([show [show a,show l,show cs,show r, show b]| (a,l,sl,cs,sr,r,b)<- @lhs.septets])) else
                      @hsgn
         loc.hsgn   = [(a,c)| (a,l,sl,cs,sr,r,b)<- @lhs.septets, length l==1, c<-cs]
         tl.isign   = if null @lhs.septets then @lhs.isign else
                      [(c,b)| (a,l,sl,cs,sr,r,b)<- @lhs.septets, length l==1, c<-cs]
         tl.septets = @septs
         loc.septs  = [ (c',tail l,rd[(c',c)|(a,c)<-sl],cs,sr,r,b)
                      | (a,l,sl,cs,sr,r,b)<- @lhs.septets,length l>1,(a',c')<- @hsgn]
  | Nil  lhs.signss = []
SEM Morphism
  | Mph lhs.signs   = if null @atts then [ (source mor,target mor) | mor <- @ms'] else [(head @atts,last @atts)]
        loc.is      = irredM @lhs.gE [ mor | mor <- @ms'
                                           , or[source mor `@lhs.gE` a && target mor `@lhs.gE` b|(a,b) <- @lhs.isign]  ]
  | Id  lhs.signs   = if null @atts then [(Anything @lhs.gE,Anything @lhs.gE)] else [(a,a)|a <- @atts]

ATTR Expression Expressions Rule Rules Pattern Patterns [ | | morphisms:{[Morphism]} ]
SEM Patterns 
  | Cons lhs.morphisms = @hd.morphisms ++ @tl.morphisms
  | Nil  lhs.morphisms = []
SEM Pattern
  | Pat lhs.morphisms  = @rules.morphisms
SEM Rules
  | Cons lhs.morphisms = @hd.morphisms ++ @tl.morphisms
  | Nil  lhs.morphisms = []
SEM Rule
  | Ru lhs.morphisms   = @antc.morphisms ++ @cons.morphisms
  | Gc lhs.morphisms   = @m.morphism : @expr.morphisms
SEM Expression
  | Tm lhs.morphisms   = [@m.morphism]
  | Tf lhs.morphisms   = [@f.morphism]
  | Tc lhs.morphisms   = @c.morphisms
  | F  lhs.morphisms   = @ts.morphisms
  | Fi lhs.morphisms   = @fs.morphisms
  | Fu lhs.morphisms   = @fs.morphisms
SEM Expressions
  | Cons lhs.morphisms = @hd.morphisms ++ @tl.morphisms
  | Nil  lhs.morphisms = []

ATTR Morphism [ | | mors: Signatures ]
SEM Morphism
  | Mph lhs.mors    = @ms'
        loc.ms      = [ mor | mor <- @lhs.mDef, name mor == @nm]
        loc.ms'     = if null @atts then @ms else
                      [ mor | mor <- @ms, source mor == head @atts, target mor == last @atts]
  | Id  lhs.mors    = []

-- Type errors
ATTR Architecture Contexts Context Patterns Pattern Rules Rule Expression Expressions Signature Signatures Morphism [ | | sErr: {[String]} ]
SEM Architecture
  | Arch lhs.sErr   = @cs.sErr
SEM Contexts 
  | Cons lhs.sErr   = @hd.sErr ++ @tl.sErr
  | Nil  lhs.sErr   = []
SEM Context
  | Ctx  lhs.sErr   = @dc.sErr
SEM Patterns 
  | Cons lhs.sErr   = @hd.sErr ++ @tl.sErr
  | Nil  lhs.sErr   = []
SEM Pattern
  | Pat lhs.sErr    = @rules.sErr ++ @pms.sErr
SEM Rules
  | Cons lhs.sErr   = @hd.sErr ++ @tl.sErr
  | Nil  lhs.sErr   = []
SEM Rule
  | Ru lhs.sErr     = {- if (\(FilePos (_,Pos l c,_))->l==41) @rulePos
                      then ["Diagnosis on Line 41"++
                            "\n@antc.signs: "++show @antc.signs++
                            "\n@cons.signs: "++show @cons.signs++
                            "\n@antc.sErr:  "++show @antc.sErr++
                            "\n@cons.sErr:  "++show @cons.sErr++
                            "\n"++showADL @r++
                            "\n@r:          "++showHS @r++"\n"] else -}
                      {- if @lhs.nr<=4 then ["Diagnose "++showADL @r++"\n"++showHS @r++"\n"] else -}
                      take 1
                       (@antc.sErr++ @cons.sErr++
                        [ "8 in "++show @rulePos++"\n   Meaningless rule.\n"
                        | null @cons.signs&&null @antc.signs]++
                        [ "1 in "++show @rulePos++"\n   Mismatch in rule:\n   "++
                          show @antc.expr++ " :: "++shSigns @antc.signs ++ "\n   does not match\n   "++
                          show @cons.expr++ " :: "++shSigns @cons.signs++"\n"
                        | null @is && not (null @antc.signs) && not (null @cons.signs)]++
                        [ "2 in "++show @rulePos++"\n   Ambiguous types: "++shSigns @is++
                          "\n   in right hand side:  "++ show @cons.expr++
                          "\n   and left hand side:  "++ show @antc.expr++"\n"
                        | length @is>1])
  | Gc lhs.sErr     = {- OBSOLETE: let sh (Mph nm pos [] _ _) [] = nm
                          sh (Mph nm pos [] _ _) sgns = nm++" :: "++show sgns
                          sh (Mph nm pos as _ _) sgns = nm++show as
                          sh (Id pos [] _) sgns = "I"++" :: "++show sgns
                          sh (Id pos cs _) sgns = "I"++show cs in -}
                      take 1
                       (  [ "12 in "++show @gluePos++
                            "\n   I not allowed as left hand side of GLUE\n"
                          | null @ms && @m.id]
                       ++ ["13 in "++show @gluePos++
                            "\n   I not allowed as right hand side of GLUE\n"
                          | anything @expr.signs]
                       ++ @m.sErr ++ @expr.sErr
                       )
SEM Expression
  | Tm lhs.sErr     = @m.sErr
  | Tf lhs.sErr     = @f.sErr
  | Tc lhs.sErr     = @c.sErr
  | F  lhs.sErr     = {- ["Diagnose on Line 41: "++
                       "\n@sgns:      "++show @sgns++
                       "\n@lhs.isign: "++show @lhs.isign++
                       "\n@ts.signss: "++show @ts.signss++
                       "\ncomps @lhs.gE @ts.signss: "++show (comps @lhs.gE @ts.signss)++
                       "\n"++gEtabG @lhs.gE (rd [c|ts<- @ts.signss,(a,b)<-ts,c<-[a,b]])++
                       "\n@trpls:     "++chain "\n->          " [show a++"#"++show ls++"#"++show sl++"#"++show cs++"#"++show sr++"#"++show rs++"#"++show b|(a,ls,sl,cs,sr,rs,b)<- @trpls]++
                       "\n@lhs.expr:  "++showHS @dis++
                       "\ntypes of chop @ts.signss: "++show [(comps @lhs.gE l,comps @lhs.gE r)| (l,r)<-chop @ts.signss]++
                       "\n@ts.exprs:   "++show @ts.exprs++"\n"
                      | (\(FilePos (_,Pos l c,_))->l==41) @lhs.pos] ++ -}
                      @ts.sErr++
                      [ "5 in "++show @lhs.pos++"\n   Type error in composing\n   "++
                        show (F ls)++" :: "++shSigns sl++
                        " with\n   "++
                        show (F rs)++" :: "++shSigns sr++"\n"
                      | (a,ls,sl,cs,sr,rs,b)<- @trpls -- neither ls nor rs are empty, by the definition of trpls
                      , anything cs
                      , not (and [isIdent m| m<-ls]&&anything sl)
                      , not (and [isIdent m| m<-rs]&&anything sr)]++
                      [ "6 in "++show @lhs.pos++"\n   Ambiguous composition of\n   "++
                        show (F ls)++" :: "++shSigns sl++
                        " with\n   "++
                        show (F rs)++" :: "++shSigns sr++
                        " over concepts "++show cs++"\n"
                      |(a,ls,sl,cs,sr,rs,b)<- @trpls, length cs>1]
  | Fu lhs.sErr     = @fs.sErr++
                      ["4 in "++show @lhs.pos++"\n   Incompatible concepts in comparing\n   "++
                       commaEng "with\n  " [show f++" :: "++shSigns s| (f,s)<-zip @fs.exprs @fs.signss]++"\n"
                       |null @sgns] 
  | Fi lhs.sErr     = {- ["Diagnose Fi on Line 41: "++
                       "\n@sgns:      "++show @sgns++
                       "\n@lhs.isign: "++show @lhs.isign++
                       "\n@fs.signss: "++show @fs.signss++
                       "\n@fs.exprs:   "++show @fs.exprs++"\n"++
                       " = "++showADL @fs.exprs++"\n"++
                       " = "++showHS @fs.exprs++"\n"
                      | (\(FilePos (_,Pos l c,_))->l==41) @lhs.pos] ++ -}
                      @fs.sErr++
                      ["4 in "++show @lhs.pos++"\n   Incompatible concepts in comparing\n   "++
                       commaEng "and\n  " [show f++" :: "++shSigns s| (f,s)<-zip @fs.exprs @fs.signss]++"\n"
                       |null @sgns]

{- Something funny here.
let a \/ b -: r, with a::X*Elephant, b::X*Horse and r::X*Animal, GEN Elephant ISA Animal, and GEN Horse ISA Animal
This situation is currently signalled as error of type 4
TODO: analyze this situation -}
SEM Expressions
  | Cons lhs.sErr   = {- if (\(FilePos (_,Pos l c,_))->l==41) @lhs.pos && name @hd.expr == "u"
                      then ["Diagnosis on Line 41 "++
                            "\n@tl.exprs:  "++show @tl.exprs++
                            "\n@septets:   "++chain "\n->          " [show a++"#"++show ls++"#"++show sl++"#"++show cs++"#"++show sr++"#"++show rs++"#"++show b|(a,ls,sl,cs,sr,rs,b)<- @lhs.septets]++
                            "\n@lhs.isign: "++show @lhs.isign++"\n"] else -}
                      @hd.sErr ++ @tl.sErr
  | Nil  lhs.sErr   = []
SEM Signature
  | Sgn lhs.sErr    = if @a.nm == @b.nm then [] else
                      let ps = @props `isc` [Trn,Rfx,Sym,Asy] in
                      if null ps then []
                      else ["9 in "++show @morPos++"\n   Heterogeneous relation "++
                            @nm++"["++ @a.nm ++"*"++ @b.nm ++
                            "]\n   may not be declared "++commaAnd [pMeaning p| p<-ps]++
                            ".\n   (This relation is heterogeneous because "++ @a.nm ++" and "++ @b.nm ++
                            "\n   are different concepts).\n"]
  | Idn lhs.sErr    = []
SEM Signatures
  | Cons lhs.sErr   = @hd.sErr ++ @tl.sErr
  | Nil  lhs.sErr   = []
SEM Morphism
  | Mph lhs.sErr    = [ "7 in "++show @pos++
                        "\n   Relation "++show (Mph @nm @pos @atts (Anything @lhs.gE,Anything (==)) (Idn (Anything (==)) posNone))++"\n   has more than two concepts.\n"
                      | length @atts >2 ]++
                      [ "3 in "++show @pos++
                        "\n   Relation " ++ show (Mph @nm @pos @atts (Anything (==),Anything (==)) (Idn (Anything (==)) posNone)) ++
                        (if null @atts then "" else show (rd @atts)) ++
                        " is not defined.\n"
                      | @ms'==[]] {- ++
                      [ "101 in "++show @pos++"\n   "++
                        "Relation "++ show (Mph @nm @pos @atts (Anything (==),Anything (==)) (Idn (Anything (==)) posNone))++" is not declared.\n   "++
                        "Please report this error to your dealer. It should never occur.\n   "++
                        "Diagnosis: null @is && null @lhs.isign,\n"++
                        "   @ms' = [ "++chain "\n          , " (map show @ms')++" ]\n"++
                        "   @ms  = [ "++chain "\n          , " (map show @ms) ++" ]\n"
                      | null @is && null @lhs.isign ] -}
  | Id  lhs.sErr    = []


ATTR Rule [ nr:{Int} | | ]
ATTR Rules Pattern Patterns [ | nr:{Int} | ]
ATTR Contexts [ | | contexts:{Contexts} ]
SEM Contexts
  | Cons lhs.contexts = @hd.context : @tl.contexts
  | Nil  lhs.contexts = []

ATTR Context [ | | context:{Context} ]
SEM Context
  | Ctx dc.nr = 1
ATTR Patterns [ | | patterns:Patterns signatures:Signatures conDefs:{[ConceptDef]} ]
SEM Patterns
  | Cons lhs.patterns    = @hd.pattern : @tl.patterns
         lhs.nr          = @tl.nr
         lhs.signatures  = @hd.signatures ++ @tl.signatures
         lhs.conDefs     = @hd.conDefs ++ @tl.conDefs
  | Nil  lhs.patterns    = []
         lhs.nr          = @lhs.nr
         lhs.signatures  = []
         lhs.conDefs     = []

ATTR Pattern [ | | pattern:Pattern signatures:Signatures conDefs:{[ConceptDef]} ]
SEM Pattern
  | Pat lhs.pattern    = Pat @nm @rules.rules @gen.list @pms.signatures @cs.conDefs
        lhs.nr         = @rules.nr
        lhs.signatures = @pms.signatures
        lhs.conDefs    = @cs.conDefs

ATTR Concepts [gE:GenR | | ]
ATTR Concept [gE:GenR | | nm:String concept:Concept ]
SEM Concept
  | C lhs.concept = C @c @lhs.gE []
      lhs.nm      = @c

ATTR ConceptDef [ | | c:{ConceptDef} ]
SEM ConceptDef
  | Cd lhs.c = Cd @pos @nm @def @ref

ATTR ConceptDefs [ | | conDefs:{[ConceptDef]} ]
SEM ConceptDefs
  | Cons lhs.conDefs = @hd.c : @tl.conDefs
  | Nil  lhs.conDefs = []

ATTR Expressions [ | | exprs:Expressions ]
SEM Expressions
  | Cons lhs.exprs = @hd.expr : @tl.exprs
  | Nil  lhs.exprs = []

ATTR Rule Rules [ | | rules:Rules ]
SEM Rules
  | Cons lhs.rules = @hd.rules ++ @tl.rules
         tl.nr     = @lhs.nr+1
         lhs.nr    = @tl.nr
  | Nil  lhs.rules = []
         lhs.nr    = @lhs.nr

SEM Rule
  | Ru loc.r     = -- Ru @c (specialize (head @is) @antc.expr) @rulePos (specialize (head @is) @cons.expr) @expl (if null @is then error("Fatal: null @is on "++show @rulePos++"\n@antc.expr = "++show @antc.expr++"\n@antc.signs = "++shSigns @antc.signs++"\n@cons.expr = "++show @cons.expr++"\n@cons.signs = "++shSigns @cons.signs) else head @is) @lhs.nr
                   Ru @c @antc.expr @rulePos @cons.expr @expl (if null @is then error("Fatal: null @is on "++show @rulePos++"\n@antc.expr = "++show @antc.expr++"\n@antc.signs = "++shSigns @antc.signs++"\n@cons.expr = "++show @cons.expr++"\n@cons.signs = "++shSigns @cons.signs) else head @is) @lhs.nr
       lhs.rules = [ @r ]
  | Gc lhs.rules = [Gc @gluePos (Mph @m.nm @m.pos @m.atts sgn m) (@expr.expr) sgn  @lhs.nr
                   | (d,c) <- @expr.signs, m <- @m.mors
                   , d `@lhs.gE` source m, c `@lhs.gE` target m  -- redundant . . .
                   , sgn<-[if null @m.atts then (source m,target m) else (head @m.atts,last @m.atts)]]
 
ATTR Gens [gE:GenR | | list:Gens ]
SEM Gens
  | Cons lhs.list = @hd.gen : @tl.list
  | Nil  lhs.list = []

ATTR Gen [gE:GenR | | gen:Gen ]
SEM Gen
  | G lhs.gen   = G @genus.concept @spec.concept

ATTR Signatures [ gE:GenR | | signatures:Signatures ]
SEM Signatures
  | Cons lhs.signatures = [m| m<-[ @hd.signature], not (isIdent m)] ++ @tl.signatures
  | Nil  lhs.signatures = []           

ATTR Morphism [ | | morphism:Morphism nm:String pos:FilePos atts:{[Concept]} id:Bool ]
SEM Morphism
  | Mph lhs.morphism = Mph @nm @pos @ats @s
                           (if null @rel then error("Fatal: null @rel in "++ @nm++" on "++show @pos++"\n@lhs.isign = "++ show @lhs.isign++"\n@ms'       = "++ show @ms'++"\n@s         = "++ show @s++"\n"++ gEtabG @lhs.gE (rd ([fst @s,snd @s]++concs @ms'))) else
                            head @rel)
        loc.rel   = [m| m <- @ms', source m `@lhs.gE` fst @s && target m `@lhs.gE` snd @s]
        loc.s     = if null @lhs.isign
                    then error("Fatal 2: Empty signature allocation for "++ @nm ++" on "++show @pos++":\n  @ms="++chain "\n       " (map show @ms)++":\n  @ms'="++chain "\n       " (map show @ms'))
                    else head @lhs.isign -- do not test for length @lhs.isign>1, because of GLUE
        loc.m     = if null @is
                    then error("Fatal 3: Empty signature allocation for "++show @nm++" on "++show @pos++":\n  @lhs.isign="++show @lhs.isign++":\n  @ms="++chain "\n       " (map show @ms)++":\n  @ms'="++chain "\n       " (map show @ms'))
                    else if length @is>1
                    then error("Fatal 6: Ambiguous signature allocation for "++show @nm++" on "++show @pos++":\n   "++
                                                         chain "\n   " (map show @is))
                    else head @is
        lhs.nm    = @nm
        lhs.pos   = @pos
        lhs.atts  = @ats
        loc.ats   = rd [C a @lhs.gE as|C a _ as<- @atts]
        lhs.id    = False
  | Id  lhs.morphism = Id @pos @ats (if s `@lhs.gE` t then t else s)
                       where (s,t) = if null @lhs.isign then error ("Fatal: null @lhs.isign in Id lhs.morphism!") else
                                     head @lhs.isign
        lhs.nm       = "I"
        lhs.pos      = @pos
        lhs.atts     = @ats
        loc.ats      = rd [C a @lhs.gE as|C a _ as<- @atts]
        lhs.id       = True
        
ATTR Signature [ gE:GenR | | nm:String signature:Signature]
SEM Signature
  | Sgn lhs.signature = Sgn @nm @a.concept @b.concept @props @prL @prM @prR @content @morPos
        lhs.nm        = @nm
  | Idn lhs.signature = Idn @c.concept @morPos
        lhs.nm        = "I"



{-
Signature propagation.
Every morphism stands for a signature in use. The signature defines name, source, target etc., whereas the morphism uses that information.
The parser must therefore find out which signature to bind to each morphism. This is how it works:
Firstly, the names must match precisely. That leaves a number of candidate signatures.
A morphism may be narrowed down to one particular signature by a user who specifies atts.
If that is the case (i.e. not (null atts)), atts determines the signature of the morphism completely.
Otherwise, all candidate signatures are propagated up to the rule level, where matching is done.
At the rule level, there must be one possible assignment of signatures, or else we have an ambiguity.
That unique assignment of signatures is propagated back in the (inherited) attribute isign.

Attribute propagation goes as follows:
1. All signatures are synthesized to one list of signatures per context.
2. Signatures are distributed over various contexts. They are made available in an inherited attribute mDef.
3. Morphisms are confronted with mDef, yielding a list @ms for each morphism, containing the visible signatures with the same name.
4. For each morphism, the possible signatures are determined in synthesized attribute @lhs.signs
5. These signatures are synthesized further until they arrive at a Rule
6. Each Rule must have a unique signature. If so, it is propagated downwards in @lhs.isign.
   If not, error messages are generated.
6.1	If isign is confronted with a morphism, the set of possibly matching signatures is determined
	in a local field @is. If this set does not contain precisely one signature, error messages are generated.
6.2	The appropriate signature of this morphism is taken from @lhs.isign.
7. Each Gc-rule must have one or more signatures. If multiple possibilities arise, one rule is generated for each
   possibility.
-}

{-
ATTR Architecture Contexts Context Patterns Pattern Rules Gens [ | | pr:String ]
SEM Architecture
  | Arch lhs.pr = @cs.pr
SEM Contexts
  | Cons lhs.pr = show @hd.pr ++ "\n\n" ++ @tl.pr
  | Nil  lhs.pr = ""
SEM Context
  | Ctx lhs.pr = "CONTEXT " ++ @nm ++ "\n" ++
                 @dc.pr ++
                 concat [nm++" :: "++name a++" x "++name b++"\n"| Sgn nm a b props prL prM prR c pos<- @ms.signatures ] ++
                 concat ["CONCEPT "++nm++" "++show def++" "++show ref++"\n"| Cd pos nm def ref<- @cs.list ] ++
                 "ENDCONTEXT"
SEM Patterns 
  | Cons lhs.pr = @hd.pr ++ "\n" ++ @tl.pr
  | Nil  lhs.pr = "" 
SEM Pattern
  | Pat lhs.pr  = "PATTERN " ++ @nm ++ "\n" ++ @rules.pr ++ "\n" ++ @gen.pr ++ "\n" ++ @pms.pr ++ "\nENDPATTERN"
SEM Rules
  | Cons lhs.pr = chain "\n" (map show) @hd.rules ++ "\n" ++ @tl.pr
  | Nil  lhs.pr = "" 
SEM Gens
  | Cons lhs.pr = show @hd.gen ++ "\n" ++ @tl.pr
  | Nil  lhs.pr = "" 
-}
